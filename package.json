{
  "name": "lazy-editor",
  "private": true,
  "version": "0.1.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:dev:ws": "tauri dev -- -- --workspace",
    "tauri:self-test:editor": "tauri dev -- -- --workspace",
    "build:selftest": "tsc -b && vite build --mode selftest",
    "test": "vitest run",
    "test:diagnose": "bash scripts/test-diagnose.sh",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "version:check": "node scripts/version-check.js",
    "version:bump": "node scripts/version-bump.js"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-fs": "^2.2.0",
    "@tauri-apps/plugin-http": "^2.2.0",
    "@tauri-apps/plugin-store": "^2.2.0",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@tiptap/extension-code-block-lowlight": "^2.11.0",
    "@tiptap/extension-link": "^2.11.0",
    "@tiptap/extension-placeholder": "^2.11.0",
    "@tiptap/extension-typography": "^2.11.0",
    "@tiptap/pm": "^2.11.0",
    "@tiptap/react": "^2.11.0",
    "@tiptap/starter-kit": "^2.11.0",
    "clsx": "^2.1.0",
    "lowlight": "^3.2.0",
    "lucide-react": "^0.468.0",
