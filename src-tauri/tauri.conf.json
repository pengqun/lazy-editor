{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Lazy Editor",
  "version": "0.1.6",
  "identifier": "com.lazy-editor.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Lazy Editor",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFGMTY1RDBBRTQ3MkRBQ0EKUldUSzJuTGtDbDBXSC9XN0liSXN1bXAvNWVUcGVnWEVxT2g3SEVFUGM5SytjOEowbnErZWh2eG8K",
      "endpoints": [
        "https://github.com/pengqun/lazy-editor/releases/latest/download/latest.json"
      ]
    }
  }
}
